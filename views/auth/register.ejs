<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Manish — Join the Conversation</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Syne:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="register.css">

</head>
<body>

<!-- ═══ NAVBAR ═══ -->
<%- include("../components/navbar") %>  

<!-- ═══ TICKER ═══ -->
<div class="ticker-wrap">
  <div class="ticker">
    <span class="ticker-item"><span class="ticker-dot">●</span>Is remote work better than office?</span>
    <span class="ticker-item"><span class="ticker-dot">●</span>Should AI replace teachers?</span>
    <span class="ticker-item"><span class="ticker-dot">●</span>Is social media destroying society?</span>
    <span class="ticker-item"><span class="ticker-dot">●</span>Best programming language in 2025?</span>
    <span class="ticker-item"><span class="ticker-dot">●</span>Does money buy happiness?</span>
    <span class="ticker-item"><span class="ticker-dot">●</span>Are electric cars the future?</span>
    <span class="ticker-item"><span class="ticker-dot">●</span>Should college be free for all?</span>
    <!-- duplicate for seamless loop -->
    <span class="ticker-item"><span class="ticker-dot">●</span>Is remote work better than office?</span>
    <span class="ticker-item"><span class="ticker-dot">●</span>Should AI replace teachers?</span>
    <span class="ticker-item"><span class="ticker-dot">●</span>Is social media destroying society?</span>
    <span class="ticker-item"><span class="ticker-dot">●</span>Best programming language in 2025?</span>
    <span class="ticker-item"><span class="ticker-dot">●</span>Does money buy happiness?</span>
    <span class="ticker-item"><span class="ticker-dot">●</span>Are electric cars the future?</span>
    <span class="ticker-item"><span class="ticker-dot">●</span>Should college be free for all?</span>
  </div>
</div>

<!-- ═══ PAGE ═══ -->
<div class="page">

  <!-- LEFT -->
  <div class="panel-left">
    <div class="eyebrow"><span class="eyebrow-dot"></span> Community platform</div>

    <h1 class="panel-heading">
      Ask anything.<br>
      <span class="line2">Every voice</span><br>
      <span class="line3">matters here.</span>
    </h1>

    <p class="panel-desc">
      Manish is where curious minds meet. Post your questions, share your perspective, and discover what people truly think — no algorithms, just real opinions.
    </p>

    <div class="stats">
      <div class="stat">
        <span class="stat-num">48K+</span>
        <span class="stat-label">Questions asked</span>
      </div>
      <div class="stat">
        <span class="stat-num">212K</span>
        <span class="stat-label">Opinions shared</span>
      </div>
      <div class="stat">
        <span class="stat-num">31K</span>
        <span class="stat-label">Members</span>
      </div>
    </div>

    <div class="questions-preview">
      <div class="q-card">
        <div class="q-top">
          <div class="q-avatar av1">RK</div>
          <span class="q-user">Rohit K.</span>
          <span class="q-tag">Tech</span>
        </div>
        <div class="q-text">Is coding still a valuable skill in the age of AI?</div>
        <div class="q-replies">💬 84 opinions · 2 hours ago</div>
      </div>
      <div class="q-card">
        <div class="q-top">
          <div class="q-avatar av2">SM</div>
          <span class="q-user">Sanya M.</span>
          <span class="q-tag">Society</span>
        </div>
        <div class="q-text">Should arranged marriages still be practiced in modern India?</div>
        <div class="q-replies">💬 217 opinions · 5 hours ago</div>
      </div>
      <div class="q-card">
        <div class="q-top">
          <div class="q-avatar av3">AP</div>
          <span class="q-user">Arjun P.</span>
          <span class="q-tag">Career</span>
        </div>
        <div class="q-text">Startup vs corporate job — which would you choose and why?</div>
        <div class="q-replies">💬 139 opinions · yesterday</div>
      </div>
    </div>
  </div>

  <!-- RIGHT (FORM) -->
  <div class="panel-right">
    <div class="form-card">
      <div class="form-header">
        <h2 class="form-title">Join <span>Manish</span></h2>
        <p class="form-sub">Already a member? <a href="/login">Sign in here</a></p>
      </div>

      <!-- OAuth -->
      <div class="oauth-row">
        <button class="oauth-btn">
          <svg viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Google
        </button>
        <button class="oauth-btn">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.419 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.268 2.75 1.026A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.026 2.747-1.026.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
          GitHub
        </button>
      </div>

      <div class="divider">or with email</div>

      <form id="form" novalidate action="/register" method="post">

        <div class="row2">
          <div class="field">
            <label for="fname">First name</label>
            <input type="text" id="fname" name="firstName" placeholder="Manish" autocomplete="given-name"/>
          </div>
          <div class="field">
            <label for="lname">Last name</label>
            <input type="text" id="lname" name="lastName" placeholder="Kumar" autocomplete="family-name"/>
          </div>
        </div>

        <div class="field">
          <label for="username">Username</label>
          <input type="text" id="username" name="userName" placeholder="@your_handle"/>
          <span class="err-msg" id="uname-err"></span>
        </div>

        <div class="field">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" placeholder="you@email.com" autocomplete="email"/>
          <span class="err-msg" id="email-err"></span>
        </div>

        <div class="field">
          <label for="pw">Password</label>
          <div class="pw-wrap">
            <input type="password" id="pw" name="password" placeholder="Create a strong password"/>
            <button type="button" class="eye" id="eye1" aria-label="Show password">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <div class="strength-bar"><div id="b1"></div><div id="b2"></div><div id="b3"></div><div id="b4"></div></div>
          <div class="strength-text" id="st"></div>
        </div>

        <div class="field">
          <label for="cpw">Confirm password</label>
          <div class="pw-wrap">
            <input type="password" id="cpw" placeholder="Repeat password"/>
            <button type="button" class="eye" id="eye2" aria-label="Show password">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <span class="err-msg" id="cpw-err"></span>
        </div>

        <!-- interests -->
        <span class="interests-label">I'm interested in</span>
        <div class="tags-grid" id="tags">
          <span class="tag-pill" data-v="tech">Technology</span>
          <span class="tag-pill" data-v="politics">Politics</span>
          <span class="tag-pill" data-v="sports">Sports</span>
          <span class="tag-pill" data-v="health">Health</span>
          <span class="tag-pill" data-v="career">Career</span>
          <span class="tag-pill" data-v="society">Society</span>
          <span class="tag-pill" data-v="science">Science</span>
          <span class="tag-pill" data-v="arts">Arts & Culture</span>
        </div>

        <label class="agree">
          <input type="checkbox" id="terms"/>
          I agree to the <a href="#">Terms of Use</a> and <a href="#">Privacy Policy</a> of Manish.
        </label>

        <button type="submit" class="btn-submit" id="submitBtn">
          Join the conversation →
        </button>

      </form>
    </div>
  </div>
</div>

<script>
// hamburger
const hbg=document.getElementById('hbg'),mob=document.getElementById('mob');
hbg.addEventListener('click',()=>{hbg.classList.toggle('open');mob.classList.toggle('open')});

// eye toggles
function eyeToggle(btnId,inputId){
  const btn=document.getElementById(btnId),inp=document.getElementById(inputId);
  btn.addEventListener('click',()=>{
    inp.type=inp.type==='password'?'text':'password';
    btn.style.color=inp.type==='text'?'var(--accent)':'var(--hint)';
  });
}
eyeToggle('eye1','pw'); eyeToggle('eye2','cpw');

// password strength
const pwInp=document.getElementById('pw');
const bars=[1,2,3,4].map(i=>document.getElementById('b'+i));
const stLabel=document.getElementById('st');
const lvl=['','Weak','Fair','Good','Strong'];
const cls=['','s-weak','s-fair','s-good','s-strong'];
pwInp.addEventListener('input',()=>{
  const v=pwInp.value;
  let s=0;
  if(v.length>=8)s++;
  if(/[A-Z]/.test(v)&&/[a-z]/.test(v))s++;
  if(/\d/.test(v))s++;
  if(/[^A-Za-z0-9]/.test(v))s++;
  bars.forEach((b,i)=>{b.className=i<s?cls[s]:''});
  stLabel.textContent=v?lvl[s]:'';
  stLabel.style.color=s<=1?'var(--danger)':s===2?'#e09530':s===3?'var(--success)':'var(--accent)';
});

// interest pills
document.querySelectorAll('.tag-pill').forEach(p=>{
  p.addEventListener('click',()=>p.classList.toggle('selected'));
});

// username live feedback
const unameInp=document.getElementById('username');
const unameErr=document.getElementById('uname-err');
unameInp.addEventListener('input',()=>{
  const v=unameInp.value.replace(/^@/,'');
  if(v&&v.length<3){unameErr.textContent='Username must be at least 3 characters'}
  else if(v&&/[^a-zA-Z0-9_]/.test(v)){unameErr.textContent='Only letters, numbers, and underscores'}
  else{unameErr.textContent=''}
});

// form submit
document.getElementById('form').addEventListener('submit',function(e){
  // e.preventDefault();
  let ok=true;

  const email=document.getElementById('email');
  const emailErr=document.getElementById('email-err');
  if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)){
    email.classList.add('err');emailErr.textContent='Enter a valid email.';ok=false;
  }else{email.classList.remove('err');emailErr.textContent=''}

  const pw=document.getElementById('pw'),cpw=document.getElementById('cpw');
  const cpwErr=document.getElementById('cpw-err');
  if(pw.value!==cpw.value||!cpw.value){
    cpw.classList.add('err');cpwErr.textContent='Passwords do not match.';ok=false;
  }else{cpw.classList.remove('err');cpwErr.textContent=''}

  if(!document.getElementById('terms').checked){
    alert('Please accept the Terms of Use to continue.');ok=false;
  }

 
  if(!ok){
    e.preventDefault();

  }else {
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.textContent = 'Creating your account...';
  }
});
</script>
</body>
</html>